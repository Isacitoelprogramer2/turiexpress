{
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/tours/tour-1",
        "destination": "/tours/tour-1.html"
      },
      {
        "source": "/tours/tour-2",
        "destination": "/tours/tour-2.html"
      },
      {
        "source": "/tours/tour-3",
        "destination": "/tours/tour-3.html"
      },
      {
        "source": "/tours/tour-4",
        "destination": "/tours/tour-4.html"
      }
    ],
    "headers": [
      {
        "source": "**/*.@(html)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
        ]
      },
      {
        "source": "**/*.@(jpg|jpeg|gif|png|webp|svg)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=604800, immutable" }
        ]
      },
      {
        "source": "**/*.@(css|js)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      }
    ]
  }
}
